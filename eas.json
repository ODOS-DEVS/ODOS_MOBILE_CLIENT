{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENABLE_GOOGLE_MAPS": "false",
        "EXPO_PUBLIC_API_URL": "https://odos-backend.onrender.com/api"
      }
    },
    "preview-maps": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_ENABLE_GOOGLE_MAPS": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "distribution": "store"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://odos-backend.onrender.com/api",
        "EXPO_PUBLIC_ENABLE_GOOGLE_MAPS": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6785652522"
      }
    }
  }
}
