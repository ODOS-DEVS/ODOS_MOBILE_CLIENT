# API (required). Use your Mac LAN IP for local device testing, or Render for staging.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Google Maps (optional; required for store map and vendor location picker)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

# Product share links (optional)
# EXPO_PUBLIC_SHARE_WEB_BASE_URL=https://your-site.com
