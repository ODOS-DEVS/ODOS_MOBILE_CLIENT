# API (required). Use your Mac LAN IP for local device testing, or Render for staging.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Google Sign-In (required in EAS builds — also set in eas.json env)
# Create Web + iOS (+ Android) OAuth clients in Google Cloud Console.
# Bundle / package ID: com.paul.odos
# Backend GOOGLE_CLIENT_IDS must list every client ID, comma-separated.
# Never reuse the Web client ID as the iOS/Android client — Google returns
# Error 400: invalid_request ("doesn't comply with OAuth 2.0 policy").
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Google Maps (optional; set ENABLE to true only when API keys are configured)
EXPO_PUBLIC_ENABLE_GOOGLE_MAPS=false
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=

# Product share links (optional)
# EXPO_PUBLIC_SHARE_WEB_BASE_URL=https://your-site.com
# EXPO_PUBLIC_APP_DOWNLOAD_URL=https://odos.app
