{
  "expo": {
    "name": "Odos Market",
    "slug": "odos-mobile-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "odosmobileexpo",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paul.odos",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "ODOS uses your location to pin your store on the map and show directions to shoppers."
      }
    },
    "android": {
      "package": "com.paul.odos",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#696969",
          "defaultChannel": "default",
          "sounds": ["./assets/sounds/vendor_order.wav"],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ODOS uses your location to pin your store on the map and show directions to shoppers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
